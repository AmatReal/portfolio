---
import { Image } from 'astro:assets';
import type { Skill } from '../data/skills';
 
interface Props {
  skill: Skill;
}
 
const { skill } = Astro.props;
 
const images = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/*',
  { eager: true }
);
 
const isRemote = skill.logo.startsWith('http');
const globKey = skill.logo.replace('src/assets/images', '../assets/images');
const imageData = isRemote ? null : images[globKey]?.default;
---
 
<div class="skill">
  {isRemote
    ? <img src={skill.logo} alt={skill.name} />
    : imageData
      ? <Image src={imageData} alt={skill.name} width={60} height={60} />
      : <img src={skill.logo} alt={skill.name} />
  }
  <h3>{skill.name}</h3>
  <p>{skill.level}</p>
</div>